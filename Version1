def MedioMagnetico(medio):

    df_medio = medio.copy()

    # Leer relación definitiva
    df = pd.read_excel(relacionDefinitiva, dtype=str)

    # Normalizar columnas
    df.columns = df.columns.str.strip()
    df_medio.columns = df_medio.columns.str.strip()

    df["Autorización"] = df["Autorización"].astype(str).str.strip().replace(" ","", regex=True)
    df["Número ID"] = df["Número ID"].astype(str).str.strip().replace(" ","", regex=True)
    df["TIPO ID AFILIADO"] = df["TIPO ID AFILIADO"].astype(str).str.strip().replace(" ","", regex=True)


    # print(df["Autorización"])

    df_medio["CONSEC_AUT"] = df_medio["CONSEC_AUT"].astype(str).str.strip()
    df_medio["NUMERO IDENTIFICACION AFILIADO"] = df_medio["NUMERO IDENTIFICACION AFILIADO"].astype(str).str.strip()


    # ------------------------------
    # CRUCE FECHA RELACION DEFINITIVA
    # ------------------------------

    df["CRUCE_AUT"] = df["Autorización"]

    ListaAutorizaciones = (df.drop_duplicates(subset="Autorización").set_index("Autorización")["Fecha Atención"])

    df_medio["FECHA_CONSOLIDADO"] = df_medio["CONSEC_AUT"].map(ListaAutorizaciones)

    df_medio["FECHA_CONSOLIDADO"] = pd.to_datetime(df_medio["FECHA_CONSOLIDADO"])
    df_medio["FECHA_CONSOLIDADO"] = df_medio["FECHA_CONSOLIDADO"].dt.strftime('%d/%m/%Y')


    # ------------------------------
    # ORDEN DEL ARCHIVO PROCESADO
    # ------------------------------


    df_medio = df_medio[["TIPO ID AFILIADO","NUMERO IDENTIFICACION AFILIADO", "auto1", "auto2", "CONSEC_AUT", "ESTADO", "FECHA_CONSOLIDADO", "FECHA_SURA", "CUPS", "NOMBRES", "CANTIDAD_AUTORIZADA", "COMODIN_1", "CANTIDAD_REALIZADA", "COMODIN_2", "CIE", "NIT"]]


    # ------------------------------
    # IDENTIFICACION DE MEDICAMENTOS
    # ------------------------------

    df_medications = pd.read_excel(TablaMedicamentos, dtype=str)

    medicamentos = df_medications["MEDICAMENTOS"].tolist()

    df_medio.loc[df_medio["CUPS"].isin(medicamentos), "CANTIDAD_REALIZADA"] = "0"


    # ------------------------------
    # FILTRAR AUTORIZACIONES VÁLIDAS
    # ------------------------------

    autorizaciones_validas = df["Autorización"].dropna().unique()

    df_validos = df_medio[
        df_medio["CONSEC_AUT"].isin(autorizaciones_validas)
    ].copy()

    # ------------------------------
    # AUTORIZACIONES FALTANTES
    # ------------------------------

    autorizaciones_medio = df_medio["CONSEC_AUT"].unique()
    faltantes_aut = set(autorizaciones_validas) - set(autorizaciones_medio)

    df_faltantes_aut = pd.DataFrame({
        "CONSEC_AUT": list(faltantes_aut),
        "NUMERO IDENTIFICACION AFILIADO": "",
        "ESTADO": "",
        "FECHA": "",
        "CUPS": "",
        "CIE": "",
        "NIT": "",
        "AUTO ERRONEA": "X",
        "USUARIO NO ENCONTRADO": ""
    })

    # ------------------------------
    # VALIDACIÓN DE USUARIOS (EN VALIDOS)
    # ------------------------------

    ids_validos = df["Número ID"].dropna().unique()

    df_validos["USUARIO NO ENCONTRADO"] = ""
    df_validos.loc[
        ~df_validos["NUMERO IDENTIFICACION AFILIADO"].isin(ids_validos),
        "USUARIO NO ENCONTRADO"
    ] = "X"

    df_validos["AUTO ERRONEA"] = ""

    # ------------------------------
    # USUARIOS FALTANTES
    # ------------------------------

    ids_medio = df_validos["NUMERO IDENTIFICACION AFILIADO"].unique()
    faltantes_id = set(ids_validos) - set(ids_medio)

    df_faltantes_id = pd.DataFrame({
        "CONSEC_AUT": "",
        "NUMERO IDENTIFICACION AFILIADO": list(faltantes_id),
        "ESTADO": "",
        "FECHA": "",
        "CUPS": "",
        "CIE": "",
        "NIT": "",
        "AUTO ERRONEA": "",
        "USUARIO NO ENCONTRADO": "X"
    })

    # ------------------------------
    # UNIRTODO
    # ------------------------------

    df_final = pd.concat(
        [df_validos, df_faltantes_aut, df_faltantes_id],
        ignore_index=True
    )

    del df_final["FECHA"]

    # ------------------------------
    # EXPORTAR
    # ------------------------------

    ruta_salida = os.path.join(carpeta_salida, "ArchivoProceso.xlsx")

    df_final.to_excel(ruta_salida, index=False)

    print("Proceso finalizado con éxito.")





medio = CruceInfo()
MedioMagnetico(medio)
