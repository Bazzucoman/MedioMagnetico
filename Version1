def CruceInfo():
    # ------------------------------
    # LECTURA DEL ARCHIVO MAESTRO
    # ------------------------------

    lista = []

    print("Leyendo archivo AUTORIZACIONES_SURA.xls ...")

    df_master = pd.read_excel(ruta_autorizaciones, dtype=str)  # Leer como texto

    # Normalizamos columnas por seguridad
    df_master.columns = df_master.columns.str.strip()
    

    # Verificación de columnas obligatorias
    required_cols = ["ORDEN/EVENTO", "NUMERO IDENTIFICACION AFILIADO"]


    df_master["ORDEN/EVENTO"] = df_master["ORDEN/EVENTO"].astype(str).str.strip().replace(" ","", regex=True)
    df_master["NUMERO IDENTIFICACION AFILIADO"] = df_master["NUMERO IDENTIFICACION AFILIADO"].astype(str).str.strip().replace(" ","", regex=True)

    for col in required_cols:
        if col not in df_master.columns:
            raise ValueError(f"La columna '{col}' no existe en AUTORIZACIONES_SURA.xls")

    # ------------------------------
    # BUSCAR Y LEER ARCHIVOS .xls
    # ------------------------------

    lista_archivos = glob.glob(os.path.join(carpeta_archivos, "*.xls")) 

    print(f"Se encontraron {len(lista_archivos)} archivos XLS para procesar.\n")

    for archivo in lista_archivos:
        print(f"Procesando archivo: {archivo}")

        # Leer como CSV forzado, con latin1 y TAB
        df1 = pd.read_csv(archivo, encoding="latin1", sep="\t", dtype=str)

        # Normalizamos columnas
        df1.columns = df1.columns.str.strip()


        

        # Validación columna CONSEC_AUT
        if "CONSEC_AUT" not in df1.columns:
            print(f"⚠️  El archivo {archivo} NO tiene la columna CONSEC_AUT. Omitido.")
            continue

        # ------------------------------
        # CRUCE DE INFORMACIÓN
        # ------------------------------

        df_merged = df1.merge(
            df_master[["ORDEN/EVENTO", "NUMERO IDENTIFICACION AFILIADO", "TIPO ID AFILIADO"]],
            left_on="CONSEC_AUT",
            right_on="ORDEN/EVENTO",
            how="left"
        )

        valor = df_merged["NUMERO IDENTIFICACION AFILIADO"].dropna().iloc[0]
        df_merged["NUMERO IDENTIFICACION AFILIADO"] = valor

        valorID = df_merged["TIPO ID AFILIADO"].dropna().iloc[0]
        df_merged["TIPO ID AFILIADO"] = valorID


        # Eliminamos la columna duplicada ORDEN/EVENTO si aparece
        if "ORDEN/EVENTO" in df_merged.columns:
            df_merged.drop(columns=["ORDEN/EVENTO"], inplace=True)


        #MAPIAR LAS COLUMNAS
        orden = list(df_merged.columns)

        df_merged = df_merged[[orden[-1]] + orden[:-1]]

        df_merged["CUPS"] = df_merged["PRESTACION_AUTORIZADA"].str.split("-").str[0]
        df_merged["NOMBRES"] = df_merged["PRESTACION_AUTORIZADA"].str.split("-").str[1]

        df_merged["auto1"] = df_merged["CONSEC_AUT"].str.split("-").str[0]
        df_merged["auto2"] = df_merged["CONSEC_AUT"].str.split("-").str[1]




        df_merged["CIE"] = df_merged["diagnostico"].str.split("-").str[0]

        df_merged["NIT"] = df_merged["PRESTADOR"].str.split(" ").str[1]

        df_merged = df_merged[df_merged["NIT"] == "890307200"]


        #DAR FORMATO A LAS FECHAS
        df_merged["FECHA"] = pd.to_datetime(df_merged["FECHA"])
        df_merged["FECHA"] = df_merged["FECHA"].dt.strftime('%d/%m/%Y')
        df_merged = df_merged.rename(columns={"FECHA": "FECHA_SURA"})


        df_merged["CANTIDAD_AUTORIZADA"] = "1"
        df_merged["CANTIDAD_REALIZADA"] = "1"
        df_merged["COMODIN_1"] = "0"
        df_merged["COMODIN_2"] = "0"


        df_merged = df_merged[["TIPO ID AFILIADO","NUMERO IDENTIFICACION AFILIADO", "auto1", "auto2", "CONSEC_AUT", "ESTADO", "FECHA_SURA", "CUPS", "NOMBRES", "CANTIDAD_AUTORIZADA", "COMODIN_1", "CANTIDAD_REALIZADA", "COMODIN_2", "CIE", "NIT"]]

        

        lista.append(df_merged)


        # ------------------------------
        # EXPORTAR RESULTADO
        # ------------------------------

    df_final = pd.concat(lista, ignore_index=True)
    df_masivo = df_final[["TIPO ID AFILIADO","NUMERO IDENTIFICACION AFILIADO", "auto1", "auto2", "CONSEC_AUT", "ESTADO", "FECHA_SURA", "CUPS", "NOMBRES", "CIE", "NIT"]]

    ruta_salida = os.path.join(carpeta_salida, "Masivo.xlsx")
    df_masivo.to_excel(ruta_salida, index=False)

    return df_final

    # print(df_final)



